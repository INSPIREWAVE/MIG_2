# MIGL v3 - Local development environment
# Copy to .env and fill in your values

PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=migl_v3
DB_USER=postgres
DB_PASSWORD=

# JWT — CHANGE THESE IN PRODUCTION
JWT_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Logging
LOG_LEVEL=INFO

# CORS (set to your frontend origin in production)
CORS_ORIGIN=*

# File storage
FILES_STORAGE_PATH=./data/uploads-v3
