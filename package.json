{
  "name": "mig-monorepo",
  "version": "2.0.1",
  "description": "M.I.G Loans Management – Monorepo root. Sub-projects: desktop/ (Electron) and saas/ (Express API).",
  "private": true,
  "scripts": {
    "start": "npm start --prefix desktop",
    "dev": "npm run dev --prefix desktop",
    "build": "npm run build --prefix desktop",
    "build:win": "npm run build:win --prefix desktop",
    "build:win-portable": "npm run build:win-portable --prefix desktop",
    "start:api": "npm start --prefix saas",
    "dev:api": "npm run dev --prefix saas",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "keywords": ["electron", "express", "loan", "management", "microfinance"],
  "author": "MIG Development",
  "license": "ISC",
  "type": "commonjs",
  "note": "Monorepo root. node_modules here is shared by both sub-projects during development. For independent deployment, run npm install inside desktop/ or saas/ separately.",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^3.9.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.2",
    "morgan": "^1.10.1",
    "pg": "^8.17.2",
    "sql.js": "^1.8.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
