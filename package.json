{
  "name": "MIG",
  "version": "2.0.1",
  "description": "Professional Loan & Client Management System",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win --publish never",
    "build:win-portable": "electron-builder --win portable --publish never",
    "build:license-manager": "pkg scripts/license-manager-standalone.js --targets node18-win-x64 --output dist/MIGL-License-Manager.exe",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "electron",
    "loan",
    "client",
    "management",
    "microfinance",
    "desktop"
  ],
  "author": "MIG Development",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "chart.js": "^3.9.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.2",
    "morgan": "^1.10.1",
    "pg": "^8.17.2",
    "sql.js": "^1.8.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "build": {
    "appId": "com.mig.loansmanagement",
    "productName": "M.I.G Loans Management",
    "asar": false,
    "files": [
      "electron/**/*",
      "src/**/*",
      "legacy/**/*",
      "index.html",
      "package.json",
      "production-config.json",
      "logo/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "logo",
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo/icon.ico",
      "publisherName": "MIG",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "M.I.G Loans Management",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false,
      "perMachine": false,
      "runAfterFinish": true,
      "warningsAsErrors": false,
      "installerIcon": "logo/icon.ico",
      "uninstallerIcon": "logo/icon.ico",
      "installerHeader": "logo/MIG-LOGO-LB.png",
      "installerSidebar": "logo/MIG-LOGO-LB.png"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "migl",
      "repo": "migl-app",
      "releaseType": "release"
    }
  }
}
